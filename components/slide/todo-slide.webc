<script webc:setup>
  const buildMDSlide = (slide) => {
    slide.title = slide.title || 'ToDo…';
    slide.md = slide.todo;
    return slide;
  }
</script>

<default-slide
  webc:nokeep
  webc:if="this.slide"
  @canvas-type="todo"
  :@slide="buildMDSlide(this.slide)"
></default-slide>
<error-slide webc:nokeep webc:else></error-slide>

<style webc:bucket="slides-core">
@layer slide.type {
  [slide-canvas=todo] {
    --slide-canvas-border: medium dashed mediumvioletred;
  }
}
</style>
