<slide-item
  webc:if="this.slide"
  :id="this.slide.id"
  :@caption="this.slide.caption"
  :@cite="this.slide.cite"
  :@note="this.slide.note"
  :@slide="this.slide"
  :@canvas-type="this.canvasType || 'default'"
  :style="slideStyles(this.slide)"
>
  <slide-content
    webc:nokeep
    :@slide="slide"
  ></slide-default>
</slide-item>
<error-slide webc:nokeep webc:else></error-slide>
